server {
  listen 80;
  # Replace with the actual public host names. Do not use a wildcard in production.
  server_name example.com www.example.com;

  return 308 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  # Replace with the actual public host names. Do not use a wildcard in production.
  server_name example.com www.example.com;

  # Configure paths managed by your certificate provider (for example certbot).
  ssl_certificate /etc/letsencrypt/live/example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;

  client_max_body_size 16k;
  client_header_timeout 10s;
  client_body_timeout 10s;
  keepalive_timeout 15s;
  server_tokens off;

  # Requires docker/nginx-http-security.conf.example to be included from nginx's http block.
  location ~ ^/api/(contact|maintenance)$ {
    limit_req zone=inquiry_per_ip burst=3 nodelay;
    limit_conn connections_per_ip 10;
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;
  }

  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;
  }

  add_header X-Content-Type-Options nosniff always;
  add_header X-Frame-Options DENY always;
  add_header Referrer-Policy strict-origin-when-cross-origin always;
  add_header Permissions-Policy "camera=(), geolocation=(), microphone=()" always;
}
